{
   "action": {
      "default_icon": {
         "128": "icons/icon128.png",
         "16": "icons/icon16.png",
         "48": "icons/icon48.png"
      },
      "default_title": "点击或按 Alt+Shift+D 启动 Liaison"
   },
   "background": {
      "service_worker": "liaison.js",
      "type": "module"
   },
   "commands": {
      "_execute_action": {
         "suggested_key": {
            "chromeos": "Alt+Shift+D",
            "linux": "Alt+Shift+D",
            "mac": "Alt+Shift+D",
            "windows": "Alt+Shift+D"
         }
      }
   },
   "description": "在任意网页上实现类似 Figma 的设计体验，调整元素样式、添加评论，并导出结构化 Prompt 给 AI 开发与协作。",
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Liaison - AI 编程定位、网页样式编辑与批注",
   "permissions": [ "activeTab", "contextMenus", "scripting", "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.4",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "toolbar/*" ]
   } ]
}
